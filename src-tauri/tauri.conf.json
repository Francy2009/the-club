{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gestore Pub",
  "version": "1.0.0",
  "identifier": "com.gestore.pub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gestore Pub",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/nsis-header.bmp",
        "licenseFile": "LICENSE",
        "strings": {
          "InstallBtn": "Installa",
          "UninstallBtn": "Disinstalla",
          "FinishBtn": "Fine"
        }
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": null,
      "infoPlist": {
        "NSHumanReadableCopyright": "© 2024 Francesco Dell'Orto",
        "CFBundleDisplayName": "Gestore Pub",
        "NSMicrophoneUsageDescription": "Accesso alla fotocamera per scanner QR code",
        "NSCameraUsageDescription": "Accesso alla fotocamera per scanner QR code"
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libayatana-appindicator3-1", "librsvg2-common"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "dialog": {
      "all": true,
      "open": true,
      "save": true
    },
    "fs": {
      "all": true,
      "scope": [
        "$APPDATA/gestore-pub/*",
        "$APPDATA/gestore-pub",
        "$DOCUMENT/gestore-pub/*",
        "$DOCUMENT/gestore-pub"
      ]
    },
    "shell": {
      "all": true,
      "open": true
    },
    "process": {
      "all": true
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/FrancescoDellOrto/Gestore-pub/releases/latest/download/{{target}}/{{current_version}}"
      ],
      "dialog": true,
      "pubkey": ""
    }
  }
}