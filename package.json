{
  "name": "gestore-pub",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000 --host 127.0.0.1",
    "dev:reset": "GESTORE_PUB_ENABLE_DEV_RESET=true VITE_GESTORE_PUB_ENABLE_DEV_RESET=true vite dev --port 3000 --host 127.0.0.1",
    "dev:lan": "vite dev --port 3000 --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "build:tauri": "vite build --mode tauri && node scripts/fix-tauri-assets.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "db:seed": "jiti prisma/seed.ts",
    "db:reset-admin": "jiti prisma/reset-admin-password.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/react-router": "1.170.8",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.14",
    "@tanstack/router-plugin": "1.168.11",
    "@yudiel/react-qr-scanner": "2.6.0",
    "jspdf": "4.2.1",
    "lucide-react": "0.545.0",
    "qrcode.react": "4.2.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwindcss": "4.3.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "0.5.20",
    "@tanstack/devtools-vite": "0.8.0",
    "@tanstack/react-devtools": "0.10.5",
    "@tanstack/react-router-devtools": "1.167.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "22.19.19",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-basic-ssl": "2.3.0",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "28.1.0",
    "prisma": "6.19.3",
    "typescript": "6.0.3",
    "vite": "^8.0.16",
    "vitest": "4.1.9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
